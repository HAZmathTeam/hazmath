            RowBox[{"x", ",", " ", "y", ",", " ", "z"}], "]"}]}], "]"}]}], 
        "]"}]}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
